<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Internal app storage -->
    <files-path name="my_files" path="." />
    <!-- Internal cache (fallback for camera temp file) -->
    <cache-path name="my_cache_images" path="." />
    <!-- App-specific external storage (camera photos go here) -->
    <external-files-path name="my_external_files" path="." />
    <!-- Shared external storage (legacy, Android ≤ 9) -->
    <external-path name="my_images" path="." />
    <!-- External cache -->
    <external-cache-path name="my_external_cache" path="." />
</paths>
